# Neon Postgres - auto-injected by the Vercel Marketplace integration
DATABASE_URL=

# Random API key the CLI / GitHub Action will use. Generate with `openssl rand -hex 32`.
LANGUINE_API_KEY=

# Optional: Ollama model slug. Default: phi3
# Examples: phi3, llama3.1, qwen2.5:7b
AI_MODEL=phi3

# Optional: Ollama-compatible endpoint. Default in code: http://127.0.0.1:11434/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# Optional: API key for a protected Ollama-compatible endpoint.
# The local Ollama daemon usually works fine with the placeholder value below.
OLLAMA_API_KEY=ollama
